<attr name="transform"><![CDATA[//#CTL2

// Transforms input record into output record.
function integer transform() {
	$out.0.* = $in.0.*;
	$out.0.emergencyContactName = $in.1.EmergencyContact;
	$out.0.emergencyContactPhone = $in.1.Phone;
	$out.0.emergencyContactUpdated = $in.1.UpdatedOn;

	return ALL;
}

