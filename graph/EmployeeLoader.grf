<attr name="transform"><![CDATA[//#CTL2

// Transforms input record into output record.
function integer transform() {
	$out.0.* = $in.0.*;
	$out.0.id = str2integer($in.0.id);
	$out.0.full_name = $in.0.name;
	$out.0.street_address = $in.0.address;
	$out.0.postal_code = $in.0.zip;
	$out.0.emergency_contact_name = $in.0.emergencyContactName;
	$out.0.emergency_contact_phone = $in.0.emergencyContactPhone;
	$out.0.emergency_contact_updated = $in.0.emergencyContactUpdated;
	$out.0.hire_date = str2date($in.0.hireDate,"yyyyMMdd");

	return ALL;
}

